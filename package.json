{
  "name": "x-media-downloader",
  "version": "2.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "vite build --mode extension-local",
    "build:release": "vite build --mode production",
    "dev": "vite build --watch --mode extension-local",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "icons": "node scripts/generate-icons.mjs",
    "knip": "knip",
    "lint": "oxlint . --deny-warnings --vitest-plugin",
    "package": "pnpm build:release && node scripts/package-extension.mjs && pnpm build",
    "test": "vitest run",
    "type": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/chrome": "^0.2.0",
    "@types/node": "^25.9.4",
    "knip": "^6.23.0",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
