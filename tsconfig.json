{
  "compilerOptions": {
    "target": "ES2025",
    "module": "ESNext",
    "lib": ["ES2025", "DOM"],
    "types": ["chrome"],
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true
  },
  "include": ["src", "vite.config.ts"]
}
